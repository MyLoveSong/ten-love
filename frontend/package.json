{
  "name": "@academic-health/frontend",
  "version": "3.0.0",
  "description": "增强学术级智能健康监测系统 - Vue前端界面",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "start": "vite preview --port 3000",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,vue --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,js,json,css,md}\"",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "dependencies": {
    "vue": "^3.3.0",
    "vue-router": "^4.2.0",
    "pinia": "^2.1.0",
    "element-plus": "^2.4.0",
    "@element-plus/icons-vue": "^2.1.0",
    "axios": "^1.6.0",
    "echarts": "^5.4.0",
    "vue-echarts": "^6.6.0",
    "dayjs": "^1.11.0",
    "lodash-es": "^4.17.0",
    "classnames": "^2.3.0",
    "@vueuse/core": "^10.5.0",
    "nprogress": "^0.2.0",
    "vue-lazyload": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/lodash-es": "^4.17.0",
    "@types/nprogress": "^0.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "typescript": "^5.3.0",
    "vue-tsc": "^1.8.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "@tailwindcss/forms": "^0.5.0",
    "@tailwindcss/typography": "^0.5.0",
    "unplugin-auto-import": "^0.16.0",
    "unplugin-vue-components": "^0.25.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "vue",
    "typescript",
    "vite",
    "element-plus",
    "health-monitoring",
    "frontend",
    "ui"
  ],
  "author": "Academic Research Team",
  "license": "MIT"
}
